    "express": "^5.2.1",
    "express-session": "^1.19.0",
    "express-validator": "^7.3.2",
    "helmet": "^8.1.0",
    "http-errors": "^2.0.1",
    "joi": "^18.1.2",
    "jsonwebtoken": "^9.0.3",
